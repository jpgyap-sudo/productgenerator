# ═══════════════════════════════════════════════════════════════════
#  Environment Variables — Product Image Studio
#  Copy this file to .env and fill in your actual values.
#  .env is gitignored — secrets stay local.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Providers ──
# OpenAI API keys: https://openai.com/api/
OPENAI_API_KEY=sk-proj-your-openai-key
OPENAI_CONTROL_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_MODEL_CHEAP=gpt-image-1-mini
OPENAI_IMAGE_QUALITY=medium
# Gemini API keys and Gemini 3 docs: https://ai.google.dev/gemini-api/docs/gemini-3
GEMINI_API_KEY=your-gemini-key
GEMINI_FIX_MODEL=gemini-2.5-flash-image
DEEPSEEK_API_KEY=your-deepseek-key
# Stability AI keys: https://platform.stability.ai/
STABILITY_API_KEY=sk-your-stability-key

# ── Google Drive (Service Account JSON as a single line) ──
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# ── Server ──
NODE_ENV=production
PORT=3000
VPS_ASSET_DIR=./vps-assets
VPS_PUBLIC_PREFIX=/vps-assets
