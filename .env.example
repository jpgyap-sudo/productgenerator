# ═══════════════════════════════════════════════════════════════════
#  Environment Variables — Product Image Studio
#  Copy this file to .env and fill in your actual values.
#  .env is gitignored — secrets stay local.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Providers ──
# OpenAI API keys: https://openai.com/api/
OPENAI_API_KEY=sk-proj-your-openai-key
OPENAI_CONTROL_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-4o          # Used for product-image matching (vision)
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_MODEL_CHEAP=gpt-image-1-mini
OPENAI_IMAGE_QUALITY=medium

# ── Batch Matching System ──
# Model for ZIP image fingerprinting (cheap model is fine for attribute extraction)
OPENAI_FINGERPRINT_MODEL=gpt-4.1-mini
# Model for final verification (gpt-4o for accuracy, gpt-4.1-mini for speed/cost)
OPENAI_VERIFY_MODEL=gpt-4.1-mini
# Delay between API calls to avoid rate limits (milliseconds)
OPENAI_VERIFY_DELAY_MS=3000
# Max concurrent OpenAI verification calls
OPENAI_MAX_CONCURRENCY=2
# Max retries for failed API calls
OPENAI_MAX_RETRIES=3
# Confidence thresholds (0-100)
MATCH_AUTO_ACCEPT=90    # Auto-accept if confidence >= 90
MATCH_REVIEW_THRESHOLD=70  # Needs review if 70-89, reject if < 70
# Candidate filtering
MAX_CANDIDATES_PER_PRODUCT=5  # Max candidates to send to OpenAI per product
MIN_CANDIDATE_SCORE=10        # Minimum attribute match score to be considered a candidate
# Gemini API keys and Gemini 3 docs: https://ai.google.dev/gemini-api/docs/gemini-3
GEMINI_API_KEY=your-gemini-key
GEMINI_FIX_MODEL=gemini-2.5-flash-image
DEEPSEEK_API_KEY=your-deepseek-key
# Stability AI keys: https://platform.stability.ai/
STABILITY_API_KEY=sk-your-stability-key

# ── Google Drive (Service Account JSON as a single line) ──
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# ── Server ──
NODE_ENV=production
PORT=3000
VPS_ASSET_DIR=./vps-assets
VPS_PUBLIC_PREFIX=/vps-assets
