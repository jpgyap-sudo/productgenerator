# ═══════════════════════════════════════════════════════════════════
#  Caddyfile — Reverse proxy for Product Image Studio
#
#  SuperRoo Cloud Dashboard runs on ports 3000 + 3001 (primary project).
#  Product Image Studio runs on port 3002 (Docker container).
#
#  Routes:
#    render.abcx124.xyz/studio/*  →  Product Image Studio (port 3002)
#    render.abcx124.xyz/*          →  SuperRoo Cloud Dashboard (port 3000)
#
#  Installation: sudo apt install -y caddy
#  Start:        sudo caddy start
#  Reload:       sudo caddy reload
# ═══════════════════════════════════════════════════════════════════

render.abcx124.xyz {
    # ── SuperRoo Cloud Dashboard (primary, port 3000) ────────────
    reverse_proxy localhost:3000

    # ── Product Image Studio (secondary, port 3002) ──────────────
    route /studio/* {
        uri strip_prefix /studio
        reverse_proxy localhost:3002
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }

    encode gzip

    log {
        output file /var/log/caddy/product-image-studio.log
        format json
    }
}
