{
  "name": "product-image-studio",
  "version": "2.0.0",
  "description": "Product Image Studio — AI-powered product photography using fal.ai Nano Banana 2",
  "private": true,
  "scripts": {
    "dev": "npx serve .",
    "build": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.mkdirSync('dist',{recursive:true});let h=fs.readFileSync('index.html','utf8');h=h.replace(/__FAL_API_KEY__/g,process.env.FAL_API_KEY||'__FAL_API_KEY__');fs.writeFileSync('dist/index.html',h);console.log('Build complete: dist/index.html created');\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@vercel/functions": "^3.5.0",
    "googleapis": "^140.0.0"
  }
}
