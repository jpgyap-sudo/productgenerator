  "description": "Product Image Studio — AI-powered product photography using OpenAI GPT Image 2 and Gemini 3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "echo 'No build step needed for VPS deployment'",
